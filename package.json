{
  "name": "lodestone-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Lodestone — a project-local code-aware Knowledge Graph for coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm test:bootstrap && pnpm -r test",
    "test:bootstrap": "vitest run --root .",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "yaml": "^2.8.3"
  }
}
