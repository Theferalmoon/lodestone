{
  "name": "lodestone-monorepo",
  "private": true,
  "version": "0.1.6",
  "description": "Lodestone — a project-local code-aware Knowledge Graph for coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm test:bootstrap && pnpm -r test",
    "test:bootstrap": "vitest run --root .",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docs:friend": "python3 scripts/docs/friend-docs-build.py",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "fast-uri": "3.1.2",
      "hono": "4.12.21",
      "ip-address": "10.1.1",
      "protobufjs": "7.5.8",
      "qs": "6.15.2"
    }
  }
}
