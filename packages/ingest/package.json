{
  "name": "@lodestone/ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lodestone ingest pipeline runtimes — embedder (transformers.js + ONNX), parsers (tree-sitter), graph builder. Section 05 ships only the embedder runtime.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./embed": {
      "types": "./dist/embed/runtime.d.ts",
      "default": "./dist/embed/runtime.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lodestone/shared": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
