{
  "name": "@lodestone/ingest",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "description": "Lodestone ingest pipeline runtimes — embedder (transformers.js + ONNX), parsers (tree-sitter), graph builder. Section 05 ships only the embedder runtime.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Theferalmoon/lodestone#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Theferalmoon/lodestone.git",
    "directory": "packages/ingest"
  },
  "bugs": {
    "url": "https://github.com/Theferalmoon/lodestone/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./embed": {
      "types": "./dist/embed/runtime.d.ts",
      "default": "./dist/embed/runtime.js"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "default": "./dist/parsers/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "default": "./dist/graph/index.js"
    },
    "./watcher": {
      "types": "./dist/watcher/index.d.ts",
      "default": "./dist/watcher/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/store/index.js"
    },
    "./store/sqlite": {
      "types": "./dist/store/sqlite.d.ts",
      "default": "./dist/store/sqlite.js"
    },
    "./clusterer": {
      "types": "./dist/clusterer/index.d.ts",
      "default": "./dist/clusterer/index.js"
    },
    "./skill-emitter": {
      "types": "./dist/skill-emitter/index.d.ts",
      "default": "./dist/skill-emitter/index.js"
    },
    "./seed-skills": {
      "types": "./dist/seed-skills/index.d.ts",
      "default": "./dist/seed-skills/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "default": "./dist/pipeline/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p . && node -e \"require('node:fs').cpSync('src/store/migrations','dist/store/migrations',{recursive:true})\" && node -e \"const fs=require('node:fs');if(fs.existsSync('models'))fs.cpSync('models','dist/models',{recursive:true});else console.warn('[build] models/ not present — skipping dist/models copy. Run pnpm bundle-models before publish.');\"",
    "bundle-models": "node scripts/bundle-models.mjs",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lodestone/shared": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.4.1",
    "chokidar": "^3.6.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "2.0.2",
    "graphology-metrics": "^2.4.0",
    "ignore": "^5.3.2",
    "onnxruntime-node": "^1.18.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.2.6",
    "graphology-types": "^0.24.8",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
