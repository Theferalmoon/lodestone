{
  "name": "@lodestone/cli",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "The `lodestone` CLI binary. Routes subcommands; status implemented; init/reindex/doctor/seed-skills/upgrade/uninstall stubbed for later sections.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lodestone": "./dist/bin/lodestone.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./main": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lodestone/ingest": "workspace:*",
    "@lodestone/shared": "workspace:*",
    "cli-progress": "^3.12.0",
    "fastest-levenshtein": "^1.0.16",
    "picocolors": "^1.1.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
