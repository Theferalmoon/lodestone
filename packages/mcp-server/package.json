{
  "name": "@lodestone/mcp-server",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "description": "Lodestone MCP server scaffold (§13). Stdio JSON-RPC server, dynamic tool registration, channel-validated envelope wrapper, in-flight backpressure cap, max_response_kb truncation guard. Tool bodies land in §14–§17.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Theferalmoon/lodestone#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Theferalmoon/lodestone.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/Theferalmoon/lodestone/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "lodestone-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lodestone/ingest": "workspace:*",
    "@lodestone/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "smol-toml": "^1.3.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
