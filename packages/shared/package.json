{
  "name": "@lodestone/shared",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "description": "Shared types, config schema, path resolver, and SQLite schema definitions for the Lodestone monorepo.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Theferalmoon/lodestone#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Theferalmoon/lodestone.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/Theferalmoon/lodestone/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
